{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "typeRoots": ["designs/preview/node_modules/@types"],
    "paths": {
      "react": ["designs/preview/node_modules/@types/react"]
    }
  },
  "include": ["designs/**/*.tsx", "designs/**/*.ts"]
}
